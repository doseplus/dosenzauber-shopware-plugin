{# Override für Dosenzauber-LineItems: × Knopf ausblenden für Items die zur
   Konfiguration gehören (Hauptprodukt + Optionen). Konfigurierte Pakete
   können nur als Ganzes via separatem Mechanismus entfernt werden. #}

{% sw_extends '@Storefront/storefront/component/line-item/element/remove.html.twig' %}

{% block component_line_item_remove %}
    {% if lineItem.payload.dpDosenzauberConfig is defined %}
        {# WD-Hauptprodukt: × entfernt die GANZE Konfiguration (WD + alle NK) #}
        <form action="{{ path('frontend.dosenzauber.remove-config', { lineItemId: lineItem.id }) }}"
              method="post"
              data-form-submit-loader="true"
              class="line-item-remove-form">
            <button type="submit"
                    class="btn btn-light btn-sm line-item-remove-button"
                    title="Konfiguration entfernen"
                    aria-label="Konfiguration entfernen">
                <span class="icon icon-x icon-sm">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </span>
            </button>
        </form>
    {% elseif lineItem.payload.dpDosenzauberOption is defined %}
        {# NK-Option: kein × — gehört zur Konfiguration #}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}
