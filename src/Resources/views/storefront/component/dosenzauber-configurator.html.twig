{#
   Dosenzauber Konfigurator Widget
   ---------------------------------
   Wird per buy-widget.html.twig auf jeder DZ-Produktseite eingeblendet.
   Erwartet Variables:  cfg (vom ConfiguratorDataProvider), product (SalesChannelProductEntity)

   Stack: Alpine.js + Tailwind CDN (kein Build-Schritt nötig im Plugin).
   Spätere Optimierung: Tailwind kompilieren und ins Theme integrieren.
#}

{% set rsw      = cfg.fixedPrices.rsw %}
{% set nkMaschine = cfg.fixedPrices.nkLgMaschine %}
{% set nkPers   = cfg.fixedPrices.nkPersonalisierung %}
{% set karteEx  = cfg.fixedPrices.karteText %}
{% set ukPlano  = cfg.fixedPrices.ukPlano %}
{% set ukKonf   = cfg.fixedPrices.ukKonfektioniert %}

{# Cover-Bild des aktuell geöffneten Shopware-Produkts (für Befüllung-Tile) #}
{% set productImageFilled = product.cover.media.url|default('') %}

{# CDN-Dependencies werden vom ResponseSubscriber separat (außerhalb des Templates)
   in den Response injiziert, damit die <script>-Tags wirklich ausgeführt werden.
   Hier nur das Stylesheet, das ist auch im <template> noch wirksam. #}

<style>
  /* Alten Neon-Konfigurator bei DZ-Produkten ausblenden (rendert nur wenn dieses Plugin aktiv ist) */
  [class*="neonConfigurator--"],
  .neonConfigurator,
  [data-neon-configurator-name] { display: none !important; }

  /* Standard Buy-Form (Mengenwahl + "In den Warenkorb") + "Als PDF speichern"
     ausblenden — wir haben eigenen Cart-Add im Konfigurator. Nur Blankomuster bleibt. */
  .product-detail-form-container,
  .pdfexport-btn-product { display: none !important; }

  /* Theilich 2026-05-18 Bug 4: Shopware-Standard-Lieferzeit-Anzeige bei DZ-Produkten
     ausblenden — Konfigurator hat eigene Lieferzeit-Anzeige "2-3 Wochen". Doppelte
     Lieferzeit-Hinweise verwirren den Kunden. */
  .product-detail-buy .product-detail-delivery-information,
  .product-detail-buy .delivery-information,
  .product-detail-buy [class*="delivery-information"],
  .product-detail-buy .product-delivery-information,
  .product-detail-buy .delivery-time { display: none !important; }

  /* Margin-Compression: Konfigurator + Contact-Box sitzen jetzt im selben Container,
     daher die default Bootstrap-Margins zwischen ihnen entfernen. */
  .product-detail-buy .dp-cfg-injected { margin: 8px 0 8px 0 !important; }
  .product-detail-buy .product-detail-contact { margin: 0 !important; }
  .product-detail-buy .product-detail-contact + * { margin-top: 0 !important; }
  /* Wenn die alte Row mit dem leeren col-lg-5 noch da ist: verstecken */
  .cms-block-container-row > .col-lg-5:empty { display: none !important; }

  /* Tailwind ist statisch vorgebaut mit vollem Preflight — identisch zum CDN-Verhalten.
     Storefront-Headings (die ja global gereset wurden) zurückbringen: */
  body h1:not(.dp-cfg h1), body .h1 { font-size: 2.5rem; font-weight: 500; line-height: 1.2; margin: 0 0 .5rem; }
  body h2:not(.dp-cfg h2), body .h2 { font-size: 2rem;   font-weight: 500; line-height: 1.2; margin: 0 0 .5rem; }
  body h3:not(.dp-cfg h3), body .h3 { font-size: 1.75rem; font-weight: 500; line-height: 1.2; margin: 0 0 .5rem; }
  body h4, body .h4 { font-size: 1.5rem;  font-weight: 500; line-height: 1.2; margin: 0 0 .5rem; }
  body h5, body .h5 { font-size: 1.25rem; font-weight: 500; line-height: 1.2; margin: 0 0 .5rem; }
  body h6, body .h6 { font-size: 1rem;    font-weight: 500; line-height: 1.2; margin: 0 0 .5rem; }
  /* Tabellen-Reset NUR im Konfigurator-Scope — Shopware-Storefront-Tabellen bleiben unangetastet */
  .dp-cfg table { border-collapse: collapse; }
  body .product-detail-name { font-size: 2.5rem; font-weight: 500; line-height: 1.2; }

  .dp-cfg { font-family: 'Inter', ui-sans-serif, system-ui; color: #4d5452; }
  .dp-cfg [x-cloak] { display: none !important; }
  .dp-cfg .num { font-variant-numeric: tabular-nums; }
  .dp-cfg h1, .dp-cfg h2, .dp-cfg h3 { color: #1d201f; font-weight: 700; line-height: 1.2; }
  .dp-cfg .toggle { position: relative; width: 44px; height: 26px; background: #d4d4d4; border-radius: 999px; cursor: pointer; transition: background .25s; flex-shrink: 0; }
  .dp-cfg .toggle::after { content:''; position:absolute; top:2px; left:2px; width:22px; height:22px; background:#fff; border-radius:50%; box-shadow:0 1px 3px rgba(0,0,0,.2); transition: transform .25s; }
  .dp-cfg .toggle.on { background: #e53009; }
  .dp-cfg .toggle.on::after { transform: translateX(18px); }
  .dp-cfg input[type=range] { -webkit-appearance:none; appearance:none; width:100%; height:6px; background: linear-gradient(to right, #e53009 var(--val,0%), #e5e5e5 var(--val,0%)); border-radius:999px; outline:none; }
  .dp-cfg input[type=range]::-webkit-slider-thumb { -webkit-appearance:none; appearance:none; width:22px; height:22px; background:#fff; border:3px solid #e53009; border-radius:50%; cursor:grab; box-shadow:0 2px 8px rgba(229,48,9,.3); }
  .dp-cfg input[type=range]::-moz-range-thumb { width:22px; height:22px; background:#fff; border:3px solid #e53009; border-radius:50%; cursor:grab; }
  .dp-cfg .card-on { border-color: #e53009 !important; background: #fef5f1 !important; }
  .dp-cfg .checkbox-sw { appearance:none; width:18px; height:18px; border:1px solid #B3B3B3; border-radius:3px; cursor:pointer; position:relative; transition:all .15s; flex-shrink:0; background:#fff; }
  .dp-cfg .checkbox-sw:checked { background:#e53009; border-color:#e53009; }
  .dp-cfg .checkbox-sw:checked::after { content:'✓'; color:#fff; position:absolute; inset:0; display:flex; align-items:center; justify-content:center; font-size:12px; font-weight:700; }
  .dp-cfg .lucide { width:1em; height:1em; display:inline-block; vertical-align:-0.125em; }
</style>

{# Stage/Live-kompatibler Base-Path für API-Routes (z.B. /dpstage/dosenzauber/add-to-cart) #}
{# cfg + productImageFilled als globale Vars setzen — vermeidet Probleme mit
   Apostrophen (FR/EN) und Quotes im HTML-Attribut #}
<script>
window.dpDosenzauberBasePath = "{{ app.request.basePath|default('') }}";
window.dpDosenzauberCfgData = {{ cfg|json_encode|raw }};
window.dpDosenzauberProductImage = {{ productImageFilled|json_encode|raw }};
</script>

{# Inline-SVG-Icons (Lucide-Pfade) — funktioniert IMMER ohne JS-Lib #}
{% set icSvg = {
    'upload-cloud':     '<path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242"/><path d="M12 12v9"/><path d="m16 16-4-4-4 4"/>',
    'x':                '<path d="M18 6 6 18"/><path d="m6 6 12 12"/>',
    'message-square-text':'<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/><path d="M13 8H7"/><path d="M17 12H7"/>',
    'lock':             '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    'alert-triangle':   '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/>',
    'package-2':        '<path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9z"/><path d="m3 9 2.45-4.9A2 2 0 0 1 7.24 3h9.52a2 2 0 0 1 1.8 1.1L21 9"/><path d="M12 3v6"/>',
    'alert-circle':     '<circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/>',
    'gift':             '<rect x="3" y="8" width="18" height="4" rx="1"/><path d="M12 8v13"/><path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/><path d="M7.5 8a2.5 2.5 0 0 1 0-5C11 3 12 8 12 8s1-5 4.5-5a2.5 2.5 0 0 1 0 5"/>',
    'truck':            '<path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/><path d="M15 18H9"/><path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/><circle cx="17" cy="18" r="2"/><circle cx="7" cy="18" r="2"/>',
    'shopping-cart':    '<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>',
    'loader-2':         '<path d="M21 12a9 9 0 1 1-6.219-8.56"/>',
    'check-circle-2':   '<path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 12 2 12s4.477 10 10 10z"/><path d="m9 12 2 2 4-4"/>'
} %}

<div class="dp-cfg"
     style="margin-top:0 !important; margin-bottom:0 !important"
     x-data="dpDosenzauberCfg(window.dpDosenzauberCfgData, window.dpDosenzauberProductImage)"
     x-init="$nextTick(() => { initSliders(); })">

    <div class="bg-white border border-stone-200 rounded-xl overflow-hidden">

        {# Plugin-Header #}
        <header class="px-5 py-4 border-b border-stone-200 bg-stone-50">
            <h2 class="text-lg leading-tight">{{ cfg.t.heading }}</h2>
            <p class="text-xs text-stone-500">{{ cfg.t.subheading }}</p>
        </header>

        {# Theilich 2026-05-18 Bug 1: Out-Of-Stock-Warnung wenn DZ-Hauptartikel ausverkauft.
           Konfigurator wird grau + Cart-Add-Button gesperrt — verhindert dass Konfigurationen
           ohne Dose im Warenkorb landen. #}
        {% if cfg.stockAvailable is defined and not cfg.stockAvailable %}
        <div class="px-5 py-4 bg-amber-50 border-b-2 border-amber-300 flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-5 h-5 text-amber-700 shrink-0 mt-0.5">{{ icSvg['alert-triangle']|raw }}</svg>
            <div>
                <p class="font-bold text-sm text-amber-900 leading-tight">Diese Dose ist aktuell ausverkauft</p>
                <p class="text-xs text-amber-900/80 mt-1 leading-snug">Sie können den Konfigurator zur Vorbereitung nutzen, eine Bestellung ist aktuell aber leider nicht möglich. Bei Interesse melden Sie sich gerne über das Kontaktformular oder per Telefon — wir prüfen die Verfügbarkeit für Sie.</p>
            </div>
        </div>
        {% endif %}

        <div class="p-5 space-y-3">

            {# 3 Toggles: Lasergravur / Befüllung / Verpackung #}
            <template x-for="(opt, idx) in options" :key="opt.key">
                <div :class="opt.on ? 'card-on' : 'border-stone-200 bg-white'"
                     class="border-2 rounded-xl transition-all overflow-hidden">

                    <div class="px-4 py-3 flex items-center gap-3 cursor-pointer" @click="toggle(idx)">
                        <div class="w-12 h-12 rounded-lg overflow-hidden border-2 shrink-0 bg-white"
                             :class="opt.on ? 'border-red-600' : 'border-stone-200 opacity-50'">
                            <img :src="opt.tile" :alt="opt.title" class="w-full h-full object-cover">
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="font-bold text-sm leading-tight" x-text="opt.title"></p>
                            <p class="text-xs text-stone-500 leading-tight" x-text="opt.subtitle"></p>
                        </div>
                        <div class="text-right shrink-0" x-show="!isAngebot()" x-cloak>
                            <p class="text-xs font-bold num" :class="opt.on ? 'text-red-600' : 'text-stone-500'"
                               x-text="opt.key === 'laser' ? `+ ${formatPrice(laserPrice())}` :
                                       (opt.key === 'fuellung' ? `+ ${formatPrice(cfg.maxRiegel * cfg.fixedPrices.rsw)}` :
                                       `+ ${formatPrice(currentVerpackungPrice())}`)"></p>
                            <p x-show="opt.key === 'laser'" class="text-[9px] text-stone-500 num leading-tight" x-text="staffelLabel()"></p>
                        </div>
                        <div :class="opt.on ? 'toggle on' : 'toggle'" @click.stop="toggle(idx)"></div>
                    </div>

                    {# Detail-Panel pro Toggle #}
                    <div x-show="opt.on" x-cloak class="border-t border-red-200 px-4 py-3 bg-white">

                        {# LASER-Detail: Logo-Upload + NK PERS #}
                        <div x-show="opt.key === 'laser'">
                            <div @click.stop="$refs.logoInput.click()"
                                 @dragover.prevent.stop="isDragging=true"
                                 @dragleave.prevent.stop="isDragging=false"
                                 @drop.prevent.stop="isDragging=false; onLogoDrop($event)"
                                 :class="isDragging || logoFile ? 'border-red-600 bg-white' : 'border-stone-200 bg-stone-50 hover:border-red-600'"
                                 class="border-2 border-dashed rounded-lg p-3 cursor-pointer flex items-center gap-3">
                                <input type="file" x-ref="logoInput" class="hidden" @change="onLogoUpload($event)" accept=".pdf,.svg,.png,.jpg">
                                <template x-if="!logoFile">
                                    <div class="flex items-center gap-3 w-full">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-5 h-5 text-stone-500 shrink-0">{{ icSvg['upload-cloud']|raw }}</svg>
                                        <div class="flex-1">
                                            <p class="text-xs font-semibold">{{ cfg.t.laser_upload }}</p>
                                            <p class="text-[10px] text-stone-500">{{ cfg.t.laser_upload_hint }}</p>
                                        </div>
                                    </div>
                                </template>
                                <template x-if="logoFile">
                                    <div class="flex items-center gap-3 w-full">
                                        <div class="w-8 h-8 bg-white border border-red-600 rounded shrink-0 p-0.5 flex items-center justify-center">
                                            <img :src="logoPreview" class="max-w-full max-h-full object-contain">
                                        </div>
                                        <div class="flex-1 min-w-0">
                                            <p class="text-xs font-semibold truncate" x-text="logoFile.name"></p>
                                            <p class="text-[10px] text-red-600">{{ cfg.t.preview_active }}</p>
                                        </div>
                                        <button @click.stop="removeLogo()" class="text-stone-500 hover:text-stone-900 p-1"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3.5 h-3.5">{{ icSvg['x']|raw }}</svg></button>
                                    </div>
                                </template>
                            </div>
                            <p class="text-[10px] text-stone-500 mt-2">
                                NK LG · + <span x-text="formatPrice(cfg.fixedPrices.nkLgMaschine)"></span> {{ cfg.t.laser_machine_setup }}
                            </p>

                            {# NK PERS · Personalisierung #}
                            <label @click.stop class="mt-2 flex items-center gap-2.5 p-2.5 rounded-lg cursor-pointer border-2"
                                   :class="laser.personalisierung ? 'border-red-600 bg-white' : 'border-stone-200 bg-stone-50 hover:border-red-600'">
                                <input type="checkbox" x-model="laser.personalisierung" class="checkbox-sw" @click.stop>
                                <div class="flex-1">
                                    <p class="text-xs font-semibold leading-tight">NK PERS · {{ cfg.t.laser_personalization }}</p>
                                    <p class="text-[10px] text-stone-500 leading-tight">{{ cfg.t.laser_pers_hint }}</p>
                                </div>
                                <span class="text-xs font-bold num shrink-0">+ <span x-text="formatPrice(cfg.fixedPrices.nkPersonalisierung)"></span></span>
                            </label>

                            {# Theilich 2026-05-19: Vorabmuster ist jetzt eigenständiger Button
                               unter der Staffel-Tabelle (wie Blankomuster) — siehe dort. #}
                        </div>

                        {# BEFÜLLUNG-Detail: feste Anzahl + Karte mit/ohne Text #}
                        <div x-show="opt.key === 'fuellung'" class="space-y-3">
                            <div class="flex items-center gap-3">
                                <div class="flex-1">
                                    <p class="text-[10px] uppercase tracking-wider text-stone-500 font-bold">{{ cfg.t.fuellung_pro_dose }}</p>
                                    <p class="text-lg font-extrabold num leading-tight mt-0.5">
                                        <span x-text="cfg.maxRiegel"></span> × {{ cfg.t.fuellung_riegel_suffix }}
                                    </p>
                                    <p class="text-[10px] text-stone-500 mt-0.5">
                                        {{ cfg.t.fuellung_mix_hint }} · <span x-text="formatPrice(cfg.fixedPrices.rsw)"></span>/Riegel
                                        · <span class="text-amber-700">{{ cfg.t.fuellung_delivery }}</span>
                                    </p>
                                </div>
                                <div class="text-right shrink-0">
                                    <p class="text-[10px] uppercase tracking-wider text-stone-500 font-bold">{{ cfg.t.fuellung_je_dose }}</p>
                                    <p class="text-lg font-extrabold num text-red-600 leading-tight mt-0.5"
                                       x-text="formatPrice(cfg.maxRiegel * cfg.fixedPrices.rsw)"></p>
                                </div>
                            </div>

                            <div>
                                <p class="text-[10px] uppercase tracking-wider text-stone-500 font-bold mb-1.5">{{ cfg.t.card_title }}</p>
                                <div class="grid grid-cols-2 gap-1.5">
                                    <template x-for="k in karteVarianten" :key="k.value">
                                        <button type="button" @click.stop="karteVariant = k.value"
                                                :class="karteVariant === k.value ? 'border-red-600 bg-red-50' : 'border-stone-200 bg-white hover:border-red-600'"
                                                class="border-2 rounded-lg p-2 text-left relative">
                                            <span x-show="karteVariant === k.value" x-cloak class="absolute top-1 right-1 w-4 h-4 bg-red-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold">✓</span>
                                            <p class="font-bold text-xs leading-tight" x-text="k.label"></p>
                                            <p class="text-[10px] text-stone-500 leading-tight mt-0.5" x-text="k.hint"></p>
                                            <p class="text-[11px] font-bold num text-red-600 mt-1" x-text="k.price > 0 ? `+ ${formatPrice(k.price)} ${cfg.t.card_custom_price}` : cfg.t.card_default_label"></p>
                                        </button>
                                    </template>
                                </div>

                                <div class="mt-3 rounded-lg p-3 cursor-text border-2"
                                     :class="karteVariant === 'persoenlich' ? 'bg-red-50 border-red-600' : 'bg-stone-50 border-stone-200 hover:border-red-600'"
                                     @click.stop="karteVariant = 'persoenlich'; $nextTick(() => $refs.karteInput.focus())">
                                    <label class="text-[10px] uppercase tracking-wider font-bold mb-2 flex items-center gap-1.5"
                                           :class="karteVariant === 'persoenlich' ? 'text-red-600' : 'text-stone-500'">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3.5 h-3.5">{{ icSvg['message-square-text']|raw }}</svg>
                                        {{ cfg.t.card_text_label }}
                                        <span x-show="karteVariant !== 'persoenlich'" class="ml-auto text-red-600 font-bold normal-case tracking-normal">{{ cfg.t.card_text_click_hint }}</span>
                                    </label>
                                    <textarea x-ref="karteInput" x-model="karteText" maxlength="450" rows="4"
                                              @click.stop @focus="karteVariant='persoenlich'" @input="karteVariant='persoenlich'"
                                              placeholder="{{ cfg.t.card_text_placeholder|e('html_attr') }}"
                                              class="w-full border-2 rounded-lg p-3 text-sm focus:outline-none focus:ring-2 focus:ring-red-200 focus:border-red-600 resize-none bg-white"
                                              :class="karteVariant === 'persoenlich' ? 'border-red-600' : 'border-stone-200'"></textarea>
                                    <div class="text-[10px] mt-1.5 flex justify-between gap-2">
                                        <span>
                                            <span x-show="karteVariant === 'persoenlich'">+ <span x-text="formatPrice(cfg.fixedPrices.karteText)"></span> {{ cfg.t.card_personal_freigabe }}</span>
                                            <span x-show="karteVariant !== 'persoenlich'">{{ cfg.t.card_text_activate }} (+<span x-text="formatPrice(cfg.fixedPrices.karteText)"></span> {{ cfg.t.card_custom_price }})</span>
                                        </span>
                                        <span class="num font-semibold whitespace-nowrap"><span x-text="karteText.length"></span> / 450</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# VERPACKUNG-Detail #}
                        <div x-show="opt.key === 'verpackung'" class="grid grid-cols-2 gap-1.5">
                            <template x-for="v in verpackungVarianten" :key="v.value">
                                <button type="button" @click.stop="if (!isVerpackungDisabled(v.value)) verpackungVariant = v.value"
                                        :disabled="isVerpackungDisabled(v.value)"
                                        :class="isVerpackungDisabled(v.value) ? 'border-stone-200 bg-stone-50 opacity-50 cursor-not-allowed' : (verpackungVariant === v.value ? 'border-red-600 bg-red-50' : 'border-stone-200 bg-white hover:border-red-600')"
                                        class="border-2 rounded-lg p-2 text-left relative">
                                    <span x-show="verpackungVariant === v.value && !isVerpackungDisabled(v.value)" x-cloak class="absolute top-1 right-1 w-4 h-4 bg-red-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold">✓</span>
                                    <span x-show="isVerpackungDisabled(v.value)" x-cloak class="absolute top-1 right-1"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3 h-3 text-stone-500">{{ icSvg['lock']|raw }}</svg></span>
                                    <p class="font-bold text-xs leading-tight" x-text="v.label"></p>
                                    <p class="text-[10px] text-stone-500 leading-tight mt-0.5" x-text="v.hint + (isVerpackungDisabled(v.value) ? ' (nur bei befüllten Dosen)' : '')"></p>
                                    <p class="text-[11px] font-bold num text-red-600 mt-1" x-text="`+ ${formatPrice(v.price)}`"></p>
                                </button>
                            </template>
                        </div>
                    </div>
                </div>
            </template>

            {# Stückzahl-Slider #}
            <div class="border-2 border-stone-200 rounded-xl p-4 mt-3">
                <div class="flex items-end justify-between mb-2">
                    <div>
                        <p class="text-[10px] uppercase tracking-wider text-stone-500 font-bold">{{ cfg.t.qty_label }} · {{ cfg.t.qty_in_cartons }} <span x-text="cfg.kartonSize"></span>{{ cfg.t.qty_cartons_suffix }}</p>
                        <div class="flex items-baseline gap-1.5 mt-1">
                            <span class="text-3xl font-extrabold num leading-none" x-text="quantity"></span>
                            <span class="text-sm text-stone-500">{{ cfg.t.qty_doses }}</span>
                            <span class="text-xs text-stone-500 num">(<span x-text="Math.ceil(quantity / cfg.kartonSize)"></span> {{ cfg.t.qty_carton }}<span x-show="Math.ceil(quantity / cfg.kartonSize) > 1">s</span>)</span>
                        </div>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] text-stone-500 num">{{ cfg.t.qty_min }} <span x-text="cfg.kartonSize"></span> · {{ cfg.t.qty_step }} <span x-text="cfg.kartonSize"></span></p>
                        <p x-show="!isAngebot()" x-cloak class="text-[10px] text-red-600 font-bold uppercase tracking-wider mt-1" x-text="staffelLabel()"></p>
                        <p x-show="isAngebot()" x-cloak class="text-[10px] text-amber-700 font-bold uppercase tracking-wider mt-1">{{ cfg.t.qty_offer_request }}</p>
                    </div>
                </div>
                <input type="range" :min="cfg.kartonSize" max="1500" :step="cfg.kartonSize"
                       :value="quantity" @input="quantity = parseInt($event.target.value, 10)"
                       :style="`--val: ${Math.max(0, Math.min(100, (quantity - cfg.kartonSize) / (1500 - cfg.kartonSize) * 100))}%`">
                <div class="relative h-4 mt-1 text-[9px] uppercase tracking-wider text-stone-500 font-bold num">
                    <span class="absolute" style="left:0%" x-text="`${cfg.kartonSize}`"></span>
                    <span class="absolute" :style="`left:${(200 - cfg.kartonSize) / (1500 - cfg.kartonSize) * 100}%; transform:translateX(-50%)`">200</span>
                    <span class="absolute" :style="`left:${(500 - cfg.kartonSize) / (1500 - cfg.kartonSize) * 100}%; transform:translateX(-50%)`">500</span>
                    <span class="absolute" :style="`left:${(1000 - cfg.kartonSize) / (1500 - cfg.kartonSize) * 100}%; transform:translateX(-50%)`">1.000</span>
                    <span class="absolute" style="right:0%">1.500</span>
                </div>
                <p x-show="options[0].on && quantity < cfg.kartonSize" x-cloak
                   class="text-[10px] text-amber-800 bg-amber-50 border border-amber-200 rounded px-2 py-1 mt-2 flex items-center gap-1.5">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3 h-3">{{ icSvg['alert-triangle']|raw }}</svg>
                    {{ cfg.t.laser_min_qty_warning }} <span x-text="cfg.kartonSize"></span> {{ cfg.t.laser_min_qty_warning2 }}
                </p>
                <div class="mt-3 pt-3 border-t border-stone-200 grid grid-cols-5 gap-1 text-center text-[10px]">
                    <template x-for="(p, i) in cfg.wdStaffel" :key="i">
                        <div :class="staffelIdx(quantity, 4) === i ? 'bg-red-50 border-red-600 text-red-600' : 'bg-white border-stone-200 text-stone-500'"
                             class="border rounded px-1 py-1">
                            <p class="font-bold leading-tight num" x-text="['<99','100+','300+','500+','1k+'][i]"></p>
                            <p class="num font-semibold leading-tight mt-0.5" x-text="formatPrice(p)"></p>
                        </div>
                    </template>
                </div>

                {# Theilich 2026-05-19: Blankomuster-Block — Agentur-Service.
                   1× WD-Dose + 1× WKN-Karte, OHNE Gravur, pauschal 4€ (= Shopware "Musterpreis").
                   Direkt im Cart-Add; gehört NICHT zur Konfiguration, ist separat löschbar. #}
                <div class="mt-3 pt-3 border-t border-stone-200 flex items-center gap-3 flex-wrap">
                    <div class="flex-1 min-w-[60%]">
                        <p class="text-xs font-semibold text-stone-900">Sie wollen vorab die Qualität der Dose einschätzen?</p>
                        <p class="text-[10px] text-stone-500 leading-snug mt-0.5">Blankomuster (Dose + Karte, ohne Gravur) — direkt in den Warenkorb · 4 € pauschal</p>
                    </div>
                    <button type="button" @click="addBlankomuster()" :disabled="blankoBusy || !cfg.stockAvailable"
                            class="bg-stone-900 hover:bg-stone-800 disabled:opacity-50 disabled:cursor-not-allowed text-white text-xs font-bold px-4 py-2 rounded transition whitespace-nowrap">
                        <span x-show="!blankoBusy">Blankomuster in den Warenkorb</span>
                        <span x-show="blankoBusy" x-cloak>Wird hinzugefügt …</span>
                    </button>
                </div>
                <p x-show="blankoSuccess" x-cloak class="text-[11px] text-green-700 mt-2 text-center" x-text="blankoSuccess"></p>
                <p x-show="blankoError" x-cloak class="text-[11px] text-red-600 mt-2 text-center" x-text="blankoError"></p>

                {# Theilich 2026-05-19: Vorabveredelungsmuster — eigenständiges Produkt mit
                   Probegravur (Logo nötig). 45€ pauschal inkl. Versand. Wie Blankomuster
                   ein eigenes Cart-Item, gehört NICHT zur Konfiguration. #}
                <div class="mt-3 pt-3 border-t border-stone-200 flex items-center gap-3 flex-wrap">
                    <div class="flex-1 min-w-[60%]">
                        <p class="text-xs font-semibold text-stone-900">Vorab die Veredelung als Muster sehen?</p>
                        <p class="text-[10px] text-stone-500 leading-snug mt-0.5">
                            Vorabveredelungsmuster (Probegravur Ihres Logos auf einer Dose, mit neutraler Karte) — direkt in den Warenkorb · 45 € pauschal inkl. Versand
                        </p>
                        <p x-show="!logoFile" x-cloak class="text-[10px] text-amber-700 leading-snug mt-1">⚠ Bitte erst Ihr Logo im Lasergravur-Block hochladen, dann ist der Button aktivierbar.</p>
                    </div>
                    <button type="button" @click="addVorabmuster()" :disabled="vorabBusy || !cfg.stockAvailable || !logoFile"
                            :title="!logoFile ? 'Erst Logo hochladen' : ''"
                            class="bg-red-600 hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed text-white text-xs font-bold px-4 py-2 rounded transition whitespace-nowrap">
                        <span x-show="!vorabBusy">Vorabmuster bestellen · 45 €</span>
                        <span x-show="vorabBusy" x-cloak>Wird hinzugefügt …</span>
                    </button>
                </div>
                <p x-show="vorabSuccess" x-cloak class="text-[11px] text-green-700 mt-2 text-center" x-text="vorabSuccess"></p>
                <p x-show="vorabError" x-cloak class="text-[11px] text-red-600 mt-2 text-center" x-text="vorabError"></p>
            </div>

            {# Theilich 2026-05-19: Versand-Hinweis nach VE (Kartons). Dynamisch je Sales-Channel.
               Wird nicht angezeigt wenn cfg.shipping null ist (FR/PL gibt's eh nicht). #}
            <div x-show="cfg.shipping" x-cloak class="bg-stone-100 border border-stone-200 rounded-lg p-3 text-xs">
                <div class="flex items-start gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-4 h-4 text-stone-500 mt-0.5 shrink-0">{{ icSvg['truck']|raw }}</svg>
                    <div class="flex-1">
                        <p class="text-[11px] text-stone-700 leading-tight">
                            <strong>Versand</strong> <span x-text="shippingTier()" class="font-semibold text-stone-900"></span>
                            <span class="text-stone-500">·</span>
                            <span x-text="`${Math.ceil(quantity / cfg.kartonSize)} ${Math.ceil(quantity / cfg.kartonSize) === 1 ? 'Karton' : 'Kartons'} (VE)`"></span>
                        </p>
                        <p class="text-[10px] text-stone-500 mt-0.5 leading-snug">
                            Berechnung im Warenkorb · <a href="/informationen/versand-und-zahlung/" target="_blank" class="underline">alle Versand-Regeln</a>
                        </p>
                    </div>
                </div>
            </div>

            {# Stücklisten-Box #}
            <details class="bg-stone-50 border border-stone-200 rounded-lg text-xs">
                <summary class="px-4 py-2.5 cursor-pointer font-semibold flex items-center justify-between hover:bg-stone-100">
                    <span class="flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-4 h-4 text-stone-500">{{ icSvg['package-2']|raw }}</svg>
                        {{ cfg.t.stueckliste_heading }} <span class="num" x-text="cfg.productNumber"></span>{{ cfg.t.stueckliste_question }}
                    </span>
                </summary>
                <div class="px-4 pb-3 space-y-1.5">
                    {# Formel-Zeile: WKN bei neutraler Karte, WKI bei persönlichem Text (Theilich 2026-05-18 Punkte 4+5).
                       UV ohne K-Suffix — gleicher Bestand für plano + konfektioniert (Punkt 2). #}
                    <p class="num font-mono text-[11px] text-stone-500 pb-1">
                        <span x-text="cfg.wd || cfg.productNumber"></span>
                        <span x-show="options[1].on && karteVariant !== 'persoenlich'"> + <span x-text="cfg.wkn"></span></span>
                        <span x-show="options[1].on && karteVariant === 'persoenlich'"> + <span x-text="cfg.wki"></span></span>
                        <span x-show="options[0].on"> + NK LG (<span x-text="cfg.gravurCode"></span>)</span>
                        <span x-show="options[0].on && laser.personalisierung"> + NK PERS</span>
                        <span x-show="options[1].on"> + <span x-text="cfg.maxRiegel"></span>× RSW</span>
                        <span x-show="options[2].on"> + <span x-text="cfg.uvNumber"></span></span>
                    </p>
                    <ul class="space-y-1 text-[11px]">
                        {# WD-Zeile: aktueller Staffelpreis + Label statt nur Range (Theilich Punkt 7).
                           cfg.wd zeigt "WD 010" (Lagerartikel), cfg.productNumber zeigt "DZ 010" (Cart-Anker). #}
                        <li>
                            <span x-text="cfg.wd || cfg.productNumber"></span> — {{ cfg.t.sl_weihnachtsdose }} ·
                            {{ cfg.t.sl_laser_aktuell }}
                            <span class="font-semibold" x-text="formatPrice(wdPrice())"></span>{{ cfg.t.sl_stueck }}
                            (<span x-text="staffelLabel()"></span>)
                        </li>
                        <li x-show="options[0].on">NK LG (<span x-text="cfg.gravurCode"></span>) — {{ cfg.t.sl_laser_aktuell }} <span class="font-semibold" x-text="formatPrice(laserPrice())"></span>{{ cfg.t.sl_stueck }} (<span x-text="staffelLabel()"></span>)</li>
                        <li x-show="options[0].on">{{ cfg.t.laser_machine_setup }} — <span x-text="formatPrice(cfg.fixedPrices.nkLgMaschine)"></span> {{ cfg.t.sl_einmalig }}</li>
                        <li x-show="options[0].on && laser.personalisierung">NK PERS — {{ cfg.t.laser_personalization }} <span x-text="formatPrice(cfg.fixedPrices.nkPersonalisierung)"></span> {{ cfg.t.sl_pauschal }}</li>
                        <li x-show="options[1].on">RSW — {{ cfg.t.sl_ritter_voll }} · <span x-text="formatPrice(cfg.fixedPrices.rsw)"></span>{{ cfg.t.sl_stueck }}</li>

                        {# WKN: neutrale Karte, bucht vom Bestand ab (Theilich Punkt 4). #}
                        <li x-show="options[1].on && karteVariant !== 'persoenlich'">
                            <span x-text="cfg.wkn"></span> — {{ cfg.t.sl_karte_dosenmotiv }}
                        </li>

                        {# WKI: Sonderanfertigung mit Wunschtext, KEIN WKN-Abzug (Theilich Punkt 5). #}
                        <li x-show="options[1].on && karteVariant === 'persoenlich'" class="space-y-0.5">
                            <div>
                                <span x-text="cfg.wki"></span> — {{ cfg.t.sl_karte_pers_text }} ·
                                <span class="font-semibold" x-text="formatPrice(cfg.fixedPrices.karteText)"></span> {{ cfg.t.sl_pauschal }}
                            </div>
                            <div x-show="karteText.trim().length > 0" class="bg-white border border-stone-200 rounded px-2 py-1 text-[10px] text-stone-700 italic" x-text="`„${karteText}“`"></div>
                        </li>

                        {# UV-Zeile: ein SKU für plano + konfektioniert (Theilich Punkt 2). #}
                        <li x-show="options[2].on && verpackungVariant === 'plano'">
                            <span x-text="cfg.uvNumber"></span> · {{ cfg.t.sl_uv_plano }} — <span x-text="cfg.uvSize"></span> · <span class="font-semibold"><span x-text="formatPrice(cfg.fixedPrices.ukPlano)"></span> {{ cfg.t.sl_plano_beigelegt }}</span>
                        </li>
                        <li x-show="options[2].on && verpackungVariant === 'konfektioniert'">
                            <span x-text="cfg.uvNumber"></span> · {{ cfg.t.sl_uv_konf }} — <span x-text="cfg.uvSize"></span> · <span class="font-semibold"><span x-text="formatPrice(cfg.fixedPrices.ukKonfektioniert)"></span> {{ cfg.t.sl_dose_im_karton }}</span>
                        </li>
                    </ul>
                </div>
            </details>

            {# Angebot-Box (ab >1000 Stück) — Icons inline-SVG damit auch bei verzögertem Lucide-Load sichtbar #}
            <div x-show="isAngebot()" x-cloak class="bg-amber-50 border-2 border-amber-300 rounded-xl p-5 mt-3 text-center">
                <div class="w-12 h-12 mx-auto mb-3 bg-amber-100 rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-amber-700"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </div>
                <p class="font-bold text-amber-900 text-lg leading-tight"><span x-text="quantity"></span> {{ cfg.t.qty_doses }} · {{ cfg.t.qty_offer_request }}</p>
                <p class="text-sm text-amber-900/80 mt-2">{{ cfg.t.qty_offer_request_text }}</p>
                <div class="mt-4 space-y-2">
                    <a href="mailto:maria.topf@dosenzauber.com" class="block bg-white border border-amber-300 hover:border-amber-500 rounded-lg py-2.5 px-4 text-sm font-semibold text-amber-900 transition flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                        maria.topf@dosenzauber.com
                    </a>
                    <a href="tel:+4936217338000" class="block bg-amber-700 hover:bg-amber-800 text-white rounded-lg py-2.5 px-4 text-sm font-bold transition flex items-center justify-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        +49 (0) 3621 733 800
                    </a>
                </div>
            </div>

            {# Gesamt + CTA (versteckt im Angebot-Modus) #}
            <div x-show="!isAngebot()" x-cloak class="bg-stone-900 text-white rounded-xl p-5 mt-3">

                {# Rabattcode-Eingabe (wenn noch nicht eingelöst) #}
                <div x-show="!promoApplied" x-cloak class="bg-stone-800 border border-stone-700 rounded-lg p-3 mb-3">
                    <p class="text-xs text-white/80 leading-snug">{{ cfg.t.promo_label }}</p>
                    <div class="flex gap-1.5 mt-2">
                        <input type="text" x-model="promoInput" @keyup.enter="applyPromo()" placeholder="Code eingeben" class="flex-1 bg-stone-700 text-white text-xs uppercase tracking-wider rounded px-2.5 py-2 placeholder-white/40 focus:outline-none focus:ring-1 focus:ring-amber-400 font-bold">
                        <button @click="applyPromo()" class="bg-amber-500 hover:bg-amber-600 text-stone-900 text-xs font-bold px-3 py-2 rounded transition">{{ cfg.t.promo_redeem }}</button>
                    </div>
                    {# Theilich 2026-05-19: Sternchen-Hinweis "Nur 1 Rabatt pro Kauf" — direkt unter dem Eingabefeld #}
                    <p class="text-[10px] text-white/50 mt-2 leading-snug">
                        * Nur ein Rabatt pro Bestellung. Bei mehreren Codes gilt automatisch der mit der höchsten Ersparnis.
                    </p>
                    <p x-show="promoError" x-cloak class="text-[10px] text-red-300 mt-1.5 flex items-center gap-1"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3 h-3">{{ icSvg['alert-circle']|raw }}</svg> <span x-text="promoError"></span></p>
                </div>

                {# Aktiver Rabattcode-Badge #}
                <div x-show="promoApplied" x-cloak class="bg-gradient-to-r from-amber-500 to-amber-600 text-white rounded-lg px-3 py-2 mb-3 flex items-center gap-2 shadow">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-4 h-4">{{ icSvg['gift']|raw }}</svg>
                    <span class="font-extrabold text-sm tracking-wide" x-text="promo.code"></span>
                    <span class="text-xs">·</span>
                    <span class="text-xs flex-1" x-text="promo.label"></span>
                    <span class="text-[10px] bg-white/20 px-1.5 py-0.5 rounded-full font-semibold">{{ cfg.t.btn_cart_added }}</span>
                    <button @click="removePromo()" class="text-white/80 hover:text-white"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3.5 h-3.5">{{ icSvg['x']|raw }}</svg></button>
                </div>

                <div class="flex items-start justify-between mb-3 gap-3 flex-wrap">
                    <div class="flex-1">
                        <p class="text-[10px] uppercase tracking-wider text-white/60 font-bold">
                            {{ cfg.t.cart_gesamt_netto }}<span x-show="promoApplied" x-cloak> · {{ cfg.t.cart_mit }} <span x-text="promo.code"></span></span>
                        </p>
                        <div class="flex items-baseline gap-2 mt-1">
                            <p class="text-3xl font-extrabold num" :class="promoApplied ? 'text-amber-300' : 'text-white'"
                               x-text="formatPrice(promoApplied ? calcGesamtMitRabatt() : calcGesamt())"></p>
                            <p x-show="promoApplied" x-cloak class="text-base text-white/50 line-through num" x-text="formatPrice(calcGesamt())"></p>
                        </div>
                        <p class="text-[10px] text-white/60 mt-0.5 num">
                            <span x-text="`${formatPrice(calcStueckpreis())} / ${cfg.t.cart_dose} × ${quantity}`"></span> = <span x-text="formatPrice(calcStueckpreis() * quantity)"></span>
                            <span x-show="promoApplied" x-cloak>· {{ cfg.t.cart_sie_sparen }} <span class="text-amber-300 font-semibold" x-text="formatPrice(calcRabatt())"></span></span>
                        </p>
                    </div>
                    <div class="text-right">
                        <p class="text-[10px] uppercase tracking-wider text-white/60 font-bold">{{ cfg.t.delivery_label }}</p>
                        <p class="text-xs font-bold flex items-center gap-1 justify-end mt-1"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3.5 h-3.5">{{ icSvg['truck']|raw }}</svg> {{ cfg.t.delivery_value }}</p>
                    </div>
                </div>

                {# Aufschlüsselung Dosen-Kosten #}
                <div class="border-t border-white/10 pt-2.5 space-y-1 text-[11px] mb-3">
                    <p class="text-[9px] uppercase tracking-wider text-white/40 font-bold mb-1">{{ cfg.t.cart_breakdown }} · <span x-text="quantity"></span> × <span x-text="formatPrice(calcStueckpreis())"></span></p>
                    <div class="flex justify-between text-white/80">
                        <span><span x-text="cfg.wd || cfg.productNumber"></span> · {{ cfg.t.cart_base }}</span>
                        <span class="num font-semibold" x-text="`${formatPrice(wdPrice())} × ${quantity} = ${formatPrice(wdPrice() * quantity)}`"></span>
                    </div>
                    <div x-show="options[0].on" class="flex justify-between text-white/80">
                        <span>+ {{ cfg.t.laser_title }}</span>
                        <span class="num font-semibold" x-text="`${formatPrice(laserPrice())} × ${quantity} = ${formatPrice(laserPrice() * quantity)}`"></span>
                    </div>
                    <div x-show="options[1].on" class="flex justify-between text-white/80">
                        <span>+ {{ cfg.t.fuellung_title }} (<span x-text="cfg.maxRiegel"></span>×)</span>
                        <span class="num font-semibold" x-text="`${formatPrice(cfg.maxRiegel * cfg.fixedPrices.rsw)} × ${quantity} = ${formatPrice(cfg.maxRiegel * cfg.fixedPrices.rsw * quantity)}`"></span>
                    </div>
                    <div x-show="options[2].on" class="flex justify-between text-white/80">
                        <span>+ {{ cfg.t.verpackung_title }} (<span x-text="verpackungVariant === 'plano' ? 'plano' : 'konf.'"></span>)</span>
                        <span class="num font-semibold" x-text="`${formatPrice(currentVerpackungPrice())} × ${quantity} = ${formatPrice(currentVerpackungPrice() * quantity)}`"></span>
                    </div>
                    <div class="flex justify-between font-bold text-white border-t border-white/10 pt-1.5 mt-1.5">
                        <span>{{ cfg.t.cart_sum_dosen }}</span>
                        <span class="num" x-text="formatPrice(calcStueckpreis() * quantity)"></span>
                    </div>
                </div>

                {# Aufschlüsselung Einmalkosten #}
                <div x-show="calcEinmalkosten() > 0" x-cloak class="border-t border-white/10 pt-2.5 space-y-1 text-[11px] mb-3">
                    <p class="text-[9px] uppercase tracking-wider text-white/40 font-bold mb-1">{{ cfg.t.cart_einmalkosten }}</p>
                    <div x-show="options[0].on" class="flex justify-between text-white/80">
                        <span>NK LG · {{ cfg.t.laser_machine_setup }}</span>
                        <span class="num font-semibold" x-text="formatPrice(cfg.fixedPrices.nkLgMaschine)"></span>
                    </div>
                    <div x-show="options[0].on && laser.personalisierung" class="flex justify-between text-white/80">
                        <span>NK PERS · {{ cfg.t.laser_personalization }}</span>
                        <span class="num font-semibold" x-text="`+ ${formatPrice(cfg.fixedPrices.nkPersonalisierung)}`"></span>
                    </div>
                    <div x-show="options[1].on && karteVariant === 'persoenlich'" class="flex justify-between text-white/80">
                        <span>{{ cfg.t.card_custom }}</span>
                        <span class="num font-semibold" x-text="`+ ${formatPrice(cfg.fixedPrices.karteText)}`"></span>
                    </div>
                    <div class="flex justify-between font-bold text-white border-t border-white/10 pt-1.5 mt-1.5">
                        <span>{{ cfg.t.cart_sum_einmal }}</span>
                        <span class="num" x-text="`+ ${formatPrice(calcEinmalkosten())}`"></span>
                    </div>
                </div>

                {# Theilich 2026-05-18 Bug 1: Stock-Check via cfg.stockAvailable. Wenn ausverkauft → Button disabled. #}
                <button type="button" @click="addToCart()" :disabled="busy || !cfg.stockAvailable"
                        :title="!cfg.stockAvailable ? 'Diese Dose ist aktuell ausverkauft' : ''"
                        class="w-full bg-red-600 hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed text-white text-sm font-bold py-3 rounded transition flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-4 h-4" x-show="!busy && cfg.stockAvailable">{{ icSvg['shopping-cart']|raw }}</svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-4 h-4" x-show="!cfg.stockAvailable">{{ icSvg['lock']|raw }}</svg>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-4 h-4 animate-spin" x-show="busy" x-cloak>{{ icSvg['loader-2']|raw }}</svg>
                    <span x-show="!busy && cfg.stockAvailable">{{ cfg.t.btn_cart_add }} · <span x-text="`${quantity} ${cfg.t.qty_doses}`"></span></span>
                    <span x-show="!cfg.stockAvailable">Aktuell ausverkauft</span>
                    <span x-show="busy" x-cloak>{{ cfg.t.btn_cart_add_busy }}</span>
                </button>
                <p x-show="cartError" x-cloak x-text="cartError" class="text-[11px] text-red-400 mt-2 text-center"></p>
                <p x-show="cartSuccess" x-cloak class="text-[11px] text-green-400 mt-2 text-center flex items-center justify-center gap-1">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide w-3.5 h-3.5">{{ icSvg['check-circle-2']|raw }}</svg>
                    <span x-text="cartSuccess"></span>
                </p>
            </div>

            <p class="text-[10px] text-stone-500 text-center my-2">
                {{ cfg.t.cart_zzgl }}
            </p>
        </div>
    </div>
</div>

<script>
window.dpDosenzauberCfg = function(cfg, productImageFilled) {
    return {
        cfg: cfg,
        productImageFilled: productImageFilled || '',
        busy: false,
        cartError: '',
        cartSuccess: '',
        isDragging: false,
        logoFile: null,
        logoPreview: null,
        quantity: cfg.kartonSize * 3, // Default: 3 Kartons
        verpackungVariant: 'konfektioniert',
        karteVariant: 'standard',
        karteText: '',
        laser: { personalisierung: false },
        blankoBusy: false,
        blankoSuccess: '',
        blankoError: '',
        vorabBusy: false,
        vorabSuccess: '',
        vorabError: '',

        options: [
            { key:'laser',      on:true,  title:cfg.t.laser_title,       subtitle:cfg.t.laser_subtitle,        price:0,
              tile:'https://shop.doseplus.de/media/0f/85/b6/1765701743/doseplus-Laser-DE.png' },
            { key:'fuellung',   on:true,  title:cfg.t.fuellung_title,    subtitle:cfg.t.fuellung_subtitle,     price:0,
              tile:'https://shop.doseplus.de/media/6a/74/1d/1778781144/doseplus-helper-rsw-real.jpg?v=2' },
            { key:'verpackung', on:true,  title:cfg.t.verpackung_title,  subtitle:cfg.t.verpackung_subtitle,   price: cfg.fixedPrices.ukKonfektioniert,
              tile:'https://shop.doseplus.de/media/7f/ca/9c/1775139337/doseplus-umkarton-DE.png' },
        ],
        karteVarianten: [
            { value:'standard',    label:cfg.t.card_default, hint:cfg.t.card_default_hint, price:0 },
            { value:'persoenlich', label:cfg.t.card_custom,  hint:cfg.t.card_custom_hint,  price: cfg.fixedPrices.karteText },
        ],
        verpackungVarianten: [
            { value:'plano',         label:cfg.t.verp_plano, hint:cfg.t.verp_plano_hint, price: cfg.fixedPrices.ukPlano },
            { value:'konfektioniert',label:cfg.t.verp_konf,  hint:cfg.t.verp_konf_hint,  price: cfg.fixedPrices.ukKonfektioniert },
        ],
        // Bekannte Rabattcodes — Backend validiert beim Cart-Add nochmal
        // Bekannte Codes nur für Vorschau-Rabatt im Konfigurator. Tatsächliche Validierung
        // + Rabatt-Anwendung passiert serverseitig in Shopware (Marketing → Promotions).
        // Unbekannte Codes werden trotzdem akzeptiert und ans Backend geschickt — dort
        // entscheidet Shopware. Bekannte Codes hier müssen mit Shopware-Promotions
        // namentlich übereinstimmen, sonst sieht der Kunde Preview-Rabatt aber keinen echten.
        // 2026-05-18: 4 neue Promo-Codes ersetzen XMAS20/WEIHNACHTEN20/DOSENZAUBER10/B2B15.
        // Code-Namen verraten den Rabatt-Wert NICHT mehr ("XMAS20" hat 20% kommuniziert).
        // WICHTEL (5%) ist auto-applied ohne Code — nicht in der Vorschau-Liste.
        knownPromos: {
            'TANNENZAUBER':     { rabatt: 0.10, label: 'Aktionsrabatt (Vorschau)' },
            'STERNENGLANZ':     { rabatt: 0.15, label: 'Geschäftskunden-Rabatt (Vorschau)' },
            'MITTERNACHTSGOLD': { rabatt: 0.20, label: 'Premium-Rabatt (Vorschau)' },
            // Alte Codes bleiben fallback-kompatibel falls Steffen sie noch nutzt:
            'XMAS20':           { rabatt: 0.20, label: 'Weihnachts-Rabatt (Vorschau)' },
        },
        promoInput: '',
        promoError: '',
        promoApplied: false,
        promo: { code: '', rabatt: 0, label: '' },

        toggle(idx) {
            this.options[idx].on = !this.options[idx].on;
            // Wenn Befüllung deaktiviert wird → "konfektioniert" ist nicht mehr erlaubt
            if (idx === 1 && !this.options[1].on && this.verpackungVariant === 'konfektioniert') {
                this.verpackungVariant = 'plano';
            }
            // Lucide-Lib entfernt — Icons sind jetzt Inline-SVG, kein createIcons() nötig
        },

        // ab >1050 Dosen: individuelles Angebot statt Auto-Preis (Puffer von 50 Stück über 1000)
        isAngebot() { return this.quantity > 1050; },

        isVerpackungDisabled(value) {
            return value === 'konfektioniert' && !this.options[1].on;
        },
        currentVerpackungPrice() {
            const v = this.verpackungVarianten.find(x => x.value === this.verpackungVariant);
            return v ? v.price : 0;
        },

        staffelIdx(qty, maxIdx) {
            if (qty >= 2000) return Math.min(5, maxIdx);
            if (qty >= 1000) return Math.min(4, maxIdx);
            if (qty >= 500)  return 3;
            if (qty >= 300)  return 2;
            if (qty >= 100)  return 1;
            return 0;
        },
        wdPrice()    { return this.cfg.wdStaffel[this.staffelIdx(this.quantity, 4)] || 0; },
        laserPrice() { return this.cfg.laserStaffel[this.staffelIdx(this.quantity, 5)] || 0; },
        staffelLabel() {
            return ['bis 99 Stk.','ab 100 Stk.','ab 300 Stk.','ab 500 Stk.','ab 1.000 Stk.','ab 2.000 Stk.'][this.staffelIdx(this.quantity, 5)];
        },

        // Theilich 2026-05-19: Versand-Hinweis nach VE (Karton). Sucht Tier in cfg.shipping.tiers.
        shippingTier() {
            if (!this.cfg.shipping) return '';
            const veCount = Math.ceil(this.quantity / this.cfg.kartonSize);
            const cur = this.cfg.shipping.currency || 'EUR';
            const fmt = (n) => new Intl.NumberFormat(this.cfg.locale || 'de-DE', { style: 'currency', currency: cur }).format(n);
            for (const tier of this.cfg.shipping.tiers) {
                if (tier.maxVe === null || veCount <= tier.maxVe) {
                    if (tier.perVe) return `${fmt(tier.perVe)} / VE · ${tier.method}`;
                    if (tier.flat)  return `${fmt(tier.flat)} pauschal · ${tier.method}`;
                }
            }
            return '';
        },

        calcStueckpreis() {
            let p = this.wdPrice();
            if (this.options[0].on) p += this.laserPrice();
            if (this.options[1].on) p += this.cfg.fixedPrices.rsw * this.cfg.maxRiegel;
            if (this.options[2].on) {
                const v = this.verpackungVarianten.find(x => x.value === this.verpackungVariant);
                p += v ? v.price : 0;
            }
            return p;
        },
        calcEinmalkosten() {
            let e = 0;
            if (this.options[0].on) e += this.cfg.fixedPrices.nkLgMaschine;
            if (this.options[0].on && this.laser.personalisierung) e += this.cfg.fixedPrices.nkPersonalisierung;
            if (this.options[1].on && this.karteVariant === 'persoenlich') e += this.cfg.fixedPrices.karteText;
            return e;
        },
        calcGesamt() { return this.calcStueckpreis() * this.quantity + this.calcEinmalkosten(); },
        calcRabatt() { return this.promoApplied ? this.calcGesamt() * this.promo.rabatt : 0; },
        calcGesamtMitRabatt() { return this.calcGesamt() - this.calcRabatt(); },

        applyPromo() {
            const code = (this.promoInput || '').trim().toUpperCase();
            this.promoError = '';
            if (!code) { this.promoError = 'Bitte Code eingeben'; return; }

            const found = this.knownPromos[code];
            if (found) {
                // Bekannter Code → Vorschau-Rabatt anzeigen
                this.promo = { code: code, rabatt: found.rabatt, label: found.label };
            } else {
                // Unbekannter Code → trotzdem akzeptieren, Shopware prüft beim Cart-Add
                this.promo = { code: code, rabatt: 0, label: 'Wird im Warenkorb geprüft' };
            }
            this.promoApplied = true;
            this.promoInput = '';
            // Lucide-Lib entfernt — Icons sind jetzt Inline-SVG, kein createIcons() nötig
        },
        removePromo() {
            this.promoApplied = false;
            this.promo = { code: '', rabatt: 0, label: '' };
            this.promoInput = '';
            this.promoError = '';
        },

        formatPrice(n) {
            if (typeof n !== 'number' || isNaN(n)) return '—';
            // Currency-Factor anwenden: rsw/nkLgMaschine etc. sind in EUR gespeichert, müssen ggf. konvertiert werden
            const value = n * (this.cfg.currencyFactor || 1);
            // Locale-Mapping: gsw-CH wird von vielen Browsern nicht unterstützt → de-CH
            let locale = (this.cfg.locale || 'de-DE').replace('_','-');
            if (locale.toLowerCase().startsWith('gsw')) locale = 'de-CH';
            const currency = this.cfg.currency || 'EUR';
            try { return new Intl.NumberFormat(locale, {style:'currency', currency}).format(value); }
            catch(e) { return new Intl.NumberFormat('de-DE', {style:'currency', currency:'EUR'}).format(value); }
        },
        updateSlider(e) {
            const t = e.target, min = +t.min, max = +t.max, val = +t.value;
            t.style.setProperty('--val', ((val-min)/(max-min)*100) + '%');
        },
        initSliders() {
            this.$el.querySelectorAll('input[type=range]').forEach(t => {
                const min = +t.min, max = +t.max, val = +t.value;
                t.style.setProperty('--val', ((val-min)/(max-min)*100) + '%');
            });
        },
        init() {
            // Sync Slider visual bei jeder quantity-Änderung (verhindert Desync nach Variant-Wechsel)
            this.$watch('quantity', () => this.$nextTick(() => this.initSliders()));
        },
        onLogoUpload(e) {
            const f = e.target.files[0]; if (!f) return;
            this.logoFile = f;
            const r = new FileReader(); r.onload = ev => this.logoPreview = ev.target.result; r.readAsDataURL(f);
            // Lucide-Lib entfernt — Icons sind jetzt Inline-SVG, kein createIcons() nötig
        },
        onLogoDrop(e) {
            const f = e.dataTransfer.files[0]; if (!f) return;
            this.logoFile = f;
            const r = new FileReader(); r.onload = ev => this.logoPreview = ev.target.result; r.readAsDataURL(f);
        },
        removeLogo() { this.logoFile = null; this.logoPreview = null; },

        async addToCart() {
            if (this.busy) return;

            // Theilich 2026-05-18 Bug 1: Stock-Defense — falls jemand den HTML-Disable
            // umgeht (z.B. via DevTools), fängt das JS hier ab.
            if (!this.cfg.stockAvailable) {
                this.cartError = 'Diese Dose ist aktuell ausverkauft.';
                return;
            }

            // Validierung: Karte-mit-pers-Text aber Textfeld leer → Auto-Fallback auf Standard-Karte
            // (Sonst zahlt Kunde 125€ für leere Karte)
            if (this.options[1].on && this.karteVariant === 'persoenlich' && !this.karteText.trim()) {
                this.karteVariant = 'standard';
            }

            this.busy = true;
            this.cartError = '';

            // Bestandsbuchungs-Hinweise für Backend (Theilich 2026-05-18 Punkte 3+4+5):
            // - WD/DZ-SKU bei jeder Bestellung abbuchen
            // - WKN bei neutraler Karte abbuchen (Punkt 4)
            // - WKI bei persönlichem Text als Sonderanfertigung – KEIN WKN-Abzug (Punkt 5)
            // - UV (plano + konfektioniert) teilen einen SKU (Punkt 2)
            const stockMovements = [
                { sku: this.cfg.wd || this.cfg.productNumber, qty: this.quantity, role: 'dose' },
            ];
            if (this.options[1].on && this.karteVariant !== 'persoenlich' && this.cfg.wkn) {
                stockMovements.push({ sku: this.cfg.wkn, qty: this.quantity, role: 'karte-neutral' });
            }
            if (this.options[2].on && this.cfg.uvNumber) {
                stockMovements.push({ sku: this.cfg.uvNumber, qty: this.quantity, role: 'umverpackung' });
            }
            const sonderanfertigung = (this.options[1].on && this.karteVariant === 'persoenlich' && this.cfg.wki)
                ? { sku: this.cfg.wki, qty: this.quantity, text: this.karteText }
                : null;

            const payload = {
                productId: this.cfg.productId,
                productNumber: this.cfg.productNumber,
                quantity: this.quantity,
                gesamt: this.calcGesamt(),
                stueckpreis: this.calcStueckpreis(),
                einmalkosten: this.calcEinmalkosten(),
                staffel: this.staffelLabel(),
                options: {
                    laser: this.options[0].on,
                    fuellung: this.options[1].on,
                    verpackung: this.options[2].on,
                },
                laser: {
                    personalisierung: this.laser.personalisierung,
                    logoFileName: this.logoFile ? this.logoFile.name : null,
                },
                fuellung: {
                    riegelProDose: this.cfg.maxRiegel,
                    karteVariant: this.karteVariant,
                    karteText: this.karteVariant === 'persoenlich' ? this.karteText : null,
                },
                verpackung: this.verpackungVariant,
                konfektionierung: this.verpackungVariant === 'konfektioniert',
                stockMovements: stockMovements,
                sonderanfertigung: sonderanfertigung,
                promo: this.promoApplied ? this.promo : null,
            };

            try {
                // CSRF: Shopware 6.6 erkennt POSTs via XmlHttpRequest-Header — keine separaten Tokens nötig
                const basePath = (window.dpDosenzauberBasePath || '');
                const res = await fetch(basePath + '/dosenzauber/add-to-cart', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify(payload),
                });

                if (!res.ok) {
                    const errBody = await res.json().catch(() => ({}));
                    throw new Error(errBody.error || ('HTTP ' + res.status));
                }

                const json = await res.json();

                // Logo separat hochladen (Multipart). Fehler hier sind BLOCKEND, weil
                // ohne Logo die Lasergravur unbrauchbar wäre.
                if (this.options[0].on && this.logoFile && json.lineItemId) {
                    try {
                        await this.uploadLogo(json.lineItemId);
                    } catch (logoErr) {
                        console.error('[Dosenzauber] Logo-Upload fehlgeschlagen:', logoErr);
                        this.cartError = 'Produkt wurde in den Warenkorb gelegt, aber das Logo konnte nicht hochgeladen werden. Bitte erneut anhängen — Datei: ' + (logoErr.message || 'unbekannter Fehler');
                        this.busy = false;
                        return;
                    }
                }

                // Falls Shopware den Rabattcode rejected hat: nicht-blockender Hinweis
                if (this.promoApplied && json.promoApplied === false) {
                    this.cartError = (json.promoError || 'Rabattcode ungültig') + ' (Produkt liegt trotzdem im Warenkorb).';
                }

                // Erfolg: auf der Produktseite bleiben + Offcanvas-Cart öffnen.
                // (B2B-Plugin blockt die /checkout/cart-Seite, aber Offcanvas geht.)
                this.openOffcanvasCart();
                this.cartSuccess = json.itemCount
                    ? `${json.itemCount} Position(en) im Warenkorb`
                    : 'Erfolgreich zum Warenkorb hinzugefügt';
                this.busy = false;
                // Auto-Reset des Success-State nach 6 Sekunden
                setTimeout(() => { this.cartSuccess = ''; }, 6000);
                return;
            } catch (e) {
                console.error('[Dosenzauber] addToCart failed:', e);
                this.cartError = 'Hinzufügen fehlgeschlagen: ' + (e.message || 'Unbekannter Fehler') + '. Bitte später erneut versuchen oder telefonisch bestellen.';
                this.busy = false;
            }
        },

        // Theilich 2026-05-19: Blankomuster (Agentur-Service) — 1× WD + 1× WKN, OHNE Gravur, 4€ pauschal.
        async addBlankomuster() {
            if (this.blankoBusy) return;
            this.blankoBusy = true;
            this.blankoError = '';
            this.blankoSuccess = '';
            try {
                const basePath = (window.dpDosenzauberBasePath || '');
                const res = await fetch(basePath + '/dosenzauber/add-blankomuster', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({
                        productId: this.cfg.productId,
                        productNumber: this.cfg.productNumber,
                        wdSku: this.cfg.wd,
                        wknSku: this.cfg.wkn,
                    }),
                });
                if (!res.ok) {
                    const errBody = await res.json().catch(() => ({}));
                    throw new Error(errBody.error || ('HTTP ' + res.status));
                }
                this.blankoSuccess = 'Blankomuster wurde zum Warenkorb hinzugefügt';
                this.openOffcanvasCart();
                setTimeout(() => { this.blankoSuccess = ''; }, 6000);
            } catch (e) {
                console.error('[Dosenzauber] addBlankomuster failed:', e);
                this.blankoError = 'Konnte nicht hinzugefügt werden: ' + (e.message || 'Fehler');
            } finally {
                this.blankoBusy = false;
            }
        },

        // Theilich 2026-05-19: Vorabveredelungsmuster — eigenständiges Produkt mit Probegravur.
        // 45€ pauschal, 1× WD + 1× WKN, Logo erforderlich (Probegravur).
        async addVorabmuster() {
            if (this.vorabBusy) return;
            if (!this.logoFile) {
                this.vorabError = 'Bitte erst Ihr Logo im Lasergravur-Block hochladen.';
                return;
            }
            this.vorabBusy = true;
            this.vorabError = '';
            this.vorabSuccess = '';
            try {
                // 1. Vorabmuster-Item ins Cart legen (4 Felder + Logo-Dateiname)
                const basePath = (window.dpDosenzauberBasePath || '');
                const res = await fetch(basePath + '/dosenzauber/add-vorabmuster', {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'Accept': 'application/json',
                    },
                    body: JSON.stringify({
                        productId: this.cfg.productId,
                        productNumber: this.cfg.productNumber,
                        wdSku: this.cfg.wd,
                        wknSku: this.cfg.wkn,
                        logoFileName: this.logoFile.name,
                    }),
                });
                if (!res.ok) {
                    const errBody = await res.json().catch(() => ({}));
                    throw new Error(errBody.error || ('HTTP ' + res.status));
                }
                const json = await res.json();

                // 2. Logo-Upload (Multipart) für den neu erstellten LineItem
                if (json.lineItemId && this.logoFile) {
                    try {
                        await this.uploadLogo(json.lineItemId);
                    } catch (logoErr) {
                        console.error('[Dosenzauber] Logo-Upload für Vorabmuster fehlgeschlagen:', logoErr);
                        this.vorabError = 'Vorabmuster im Warenkorb, aber Logo konnte nicht hochgeladen werden — bitte im Cart erneut anhängen.';
                        this.vorabBusy = false;
                        return;
                    }
                }
                this.vorabSuccess = 'Vorabveredelungsmuster wurde zum Warenkorb hinzugefügt';
                this.openOffcanvasCart();
                setTimeout(() => { this.vorabSuccess = ''; }, 6000);
            } catch (e) {
                console.error('[Dosenzauber] addVorabmuster failed:', e);
                this.vorabError = 'Konnte nicht hinzugefügt werden: ' + (e.message || 'Fehler');
            } finally {
                this.vorabBusy = false;
            }
        },

        openOffcanvasCart() {
            // 1. Shopware-PluginManager-Instance (wenn vorhanden)
            try {
                if (window.PluginManager) {
                    const elements = document.querySelectorAll('[data-offcanvas-cart]');
                    elements.forEach(el => {
                        const plugin = window.PluginManager.getPluginInstanceFromElement(el, 'OffCanvasCart');
                        if (plugin && typeof plugin.openOffCanvas === 'function') plugin.openOffCanvas();
                    });
                }
            } catch (e) { /* ignore */ }

            // 2. Fallback: Cart-Icon klicken (öffnet Offcanvas)
            try {
                const cartTrigger = document.querySelector('.header-cart [data-offcanvas-cart-trigger], .header-cart a[href*="cart"], .header-cart-link');
                if (cartTrigger) cartTrigger.click();
            } catch (e) { /* ignore */ }
        },

        async uploadLogo(lineItemId) {
            if (!this.logoFile) return;
            const fd = new FormData();
            fd.append('lineItemId', lineItemId);
            fd.append('logo', this.logoFile);
            const basePath = (window.dpDosenzauberBasePath || '');
            const res = await fetch(basePath + '/dosenzauber/upload-logo', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: fd,
            });
            if (!res.ok) {
                const err = await res.json().catch(() => ({}));
                throw new Error(err.error || ('HTTP ' + res.status));
            }
            return res.json();
        },
    };
};
</script>
