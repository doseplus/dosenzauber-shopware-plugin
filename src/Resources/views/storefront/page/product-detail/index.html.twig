{# Override auf höherer Ebene (index.html.twig statt buy-widget.html.twig)
   Überlebt Theme-Overrides die das buy-widget.html.twig komplett ersetzen
   (z.B. Doseplus-Theme rendert eigenen Sidebar-Block)
#}
{% sw_extends '@Storefront/storefront/page/product-detail/index.html.twig' %}

{% block page_product_detail_buy_widget %}
    {% if page.dpDosenzauberActive %}
        {% sw_include '@DoseplusDosenzauberConfigurator/storefront/component/dosenzauber-configurator.html.twig' with {
            cfg: page.dpDosenzauberData,
            product: page.product
        } %}
    {% endif %}

    {{ parent() }}
{% endblock %}
