{# ─────────────────────────────────────────────────────────────────────
   Universeller Block-Override: base_body_after
   ─────────────────────────────────────────────────────────────────────
   Dieser Block ist GANZ am Ende von <body>. Er wird IMMER gerendert,
   auch wenn ein Theme alle inneren Templates (buy-widget, index, ...)
   komplett ersetzt. Robust gegen Theme-Hierarchie-Probleme.

   Der Konfigurator wird hier als <template> ausgegeben + ein kleines JS
   das den Inhalt in die richtige Position auf der Produktseite injiziert
   (.product-detail-buy oder Fallbacks).
─────────────────────────────────────────────────────────────────────#}
{% sw_extends '@Storefront/storefront/base.html.twig' %}

{% block base_body_after %}
    {{ parent() }}

    {% if page.dpDosenzauberActive ?? false %}
        {# Konfigurator als <template> ausgeben — wird nicht direkt gerendert,
           sondern via JS in .product-detail-buy injiziert. #}
        <template id="dp-cfg-source">
            {% sw_include '@DoseplusDosenzauberConfigurator/storefront/component/dosenzauber-configurator.html.twig' with {
                cfg: page.dpDosenzauberData,
                product: page.product
            } %}
        </template>

        <script>
        (function () {
            'use strict';

            function getBuyArea() {
                // Mehrere Fallback-Selektoren — sucht die rechte Sidebar bzw. den Haupt-Container
                return document.querySelector('.product-detail-buy')
                    || document.querySelector('.product-detail-content-main')
                    || document.querySelector('.product-detail-main')
                    || document.querySelector('.product-detail');
            }

            function alreadyInjected() {
                return !!document.querySelector('.dp-cfg');
            }

            function inject() {
                if (alreadyInjected()) return true; // Konfigurator wurde schon via Twig-Block gerendert
                var src = document.getElementById('dp-cfg-source');
                if (!src) return false;
                var area = getBuyArea();
                if (!area) return false;

                var wrapper = document.createElement('div');
                wrapper.className = 'dp-cfg-injected';
                wrapper.innerHTML = src.innerHTML;
                area.insertBefore(wrapper, area.firstChild);

                // Alpine.js für injizierten Bereich initialisieren
                if (window.Alpine && typeof window.Alpine.initTree === 'function') {
                    try { window.Alpine.initTree(wrapper); } catch(e) {}
                }
                // Lucide-Icons re-init
                if (window.lucide && typeof window.lucide.createIcons === 'function') {
                    try { window.lucide.createIcons(); } catch(e) {}
                }
                return true;
            }

            function tryInjectWithRetries() {
                if (inject()) return;
                // Wenn DOM oder Alpine noch nicht ready: nochmal versuchen
                var attempts = [50, 150, 500, 1500, 3000];
                attempts.forEach(function(delay) {
                    setTimeout(function() { inject(); }, delay);
                });
            }

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', tryInjectWithRetries);
            } else {
                tryInjectWithRetries();
            }
        })();
        </script>
    {% endif %}
{% endblock %}
