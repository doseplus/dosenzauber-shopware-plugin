<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services
           http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <service id="Doseplus\DosenzauberConfigurator\Service\ConfiguratorDataProvider">
            <argument type="service" id="Psr\Log\LoggerInterface"/>
        </service>

        <service id="Doseplus\DosenzauberConfigurator\Storefront\Subscriber\ProductPageSubscriber">
            <argument type="service" id="Doseplus\DosenzauberConfigurator\Service\ConfiguratorDataProvider"/>
            <tag name="kernel.event_subscriber"/>
        </service>
    </services>
</container>
