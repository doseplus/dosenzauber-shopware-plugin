{% block dp_cart_list %}
<sw-page class="dp-cart-list">
    <template #search-bar>
        <sw-search-bar></sw-search-bar>
    </template>

    <template #smart-bar-header>
        <h2>{{ $tc('dp-cart-overview.list.title') }}</h2>
    </template>

    <template #smart-bar-actions>
        <sw-button @click="loadCarts" variant="primary" :is-loading="loading">
            {{ $tc('dp-cart-overview.list.refresh') }}
        </sw-button>
    </template>

    <template #content>
        <sw-card-view>
            <sw-card v-if="error" variant="alert">
                <sw-alert variant="error">{{ error }}</sw-alert>
            </sw-card>

            <sw-card v-else-if="loading">
                <sw-loader></sw-loader>
            </sw-card>

            <sw-card v-else-if="carts.length === 0">
                <sw-empty-state
                    icon="regular-shopping-basket"
                    :title="$tc('dp-cart-overview.list.empty')">
                </sw-empty-state>
            </sw-card>

            <sw-card v-else :title="`${carts.length} aktive Warenkörbe`">
                <table class="dp-cart-list-table">
                    <thead>
                        <tr>
                            <th>{{ $tc('dp-cart-overview.list.columnToken') }}</th>
                            <th>{{ $tc('dp-cart-overview.list.columnCustomer') }}</th>
                            <th>{{ $tc('dp-cart-overview.list.columnUpdated') }}</th>
                            <th>{{ $tc('dp-cart-overview.list.columnPositions') }}</th>
                            <th class="text-right">{{ $tc('dp-cart-overview.list.columnTotal') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="cart in carts" :key="cart.token">
                            <td>
                                <code>{{ cart.token.substring(0, 12) }}…</code>
                                <div v-if="cart.name && cart.name !== cart.token" class="dp-cart-list-secondary">
                                    {{ cart.name }}
                                </div>
                            </td>
                            <td>
                                <span v-if="cart.customerId">
                                    <router-link :to="{ name: 'sw.customer.detail', params: { id: cart.customerId } }">
                                        {{ cart.customerId.substring(0, 8) }}…
                                    </router-link>
                                </span>
                                <span v-else class="dp-cart-list-secondary">Gast</span>
                            </td>
                            <td>{{ formatDate(cart.updatedAt) }}</td>
                            <td>
                                <ul class="dp-cart-list-items">
                                    <li v-for="(item, i) in cart.dpLineItems" :key="i">
                                        <strong>{{ item.quantity }}×</strong>
                                        {{ item.label }}
                                        <div class="dp-cart-list-config">{{ configSummary(item) }}</div>
                                    </li>
                                </ul>
                            </td>
                            <td class="text-right">{{ formatPrice(cart.totalPrice) }}</td>
                        </tr>
                    </tbody>
                </table>
            </sw-card>
        </sw-card-view>
    </template>
</sw-page>
{% endblock %}
